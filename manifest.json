{
  "manifest_version": 3,
  "name": "New Tab",
  "version": "0.1.0",
  "description": "Replaces the New Tab page with a clean custom dashboard.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "Open Dashboard"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  }
}